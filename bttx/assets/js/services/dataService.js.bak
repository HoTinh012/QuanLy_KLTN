/**
 * Sync computed fields between collections
 */
export function syncSchemas(data) {
    if (data.TenDetai) {
        data.TenDetai.forEach(t => {
            if (!t.NH) t.NH = "2026-2027";
            if (!t.HK) t.HK = "1";
            if (!t.Status) t.Status = "START";
            // ERD: Role = BCTT or KLTN (thay cho FlowType cũ)
            if (!t.Role) t.Role = (t.Loaidetai === "BCTT") ? "BCTT" : "KLTN";
            
            if (!t.EmailGV) {
                const assign = (data.Trangthaidetai || []).find(st => st.EmailSV === t.EmailSV && st.Loai === t.Role);
                if (assign) t.EmailGV = assign.EmailGV;
            }
        });
    }

    if (data.Trangthaidetai) {
        data.Trangthaidetai.forEach(st => {
            if (!st.Location) st.Location = "Online";
            // ERD: Loai = BCTT or KLTN (thay cho FlowType cũ)
            const topic = (data.TenDetai || []).find(t => t.EmailSV === st.EmailSV && t.Role === st.Loai);
            if (topic) {
                st.TenDeTai = topic.TenDeTai;
                st.TrangThai = topic.Status;
            }
        });
    }
}

/**
 * Load data from Firebase (async). Falls back to localStorage.
 */
export async function loadData() {
    try {
        const docRef = doc(db, "appData", "main");
        const docSnap = await getDoc(docRef);
        
        if (docSnap.exists()) {
            const data = docSnap.data();
            if (!data.Trangthaidetai) data.Trangthaidetai = [];
            if (!data.TenDetai) data.TenDetai = [];
            if (!data.Bienban) data.Bienban = [];
            if (!data.Hoso) data.Hoso = [];
            if (!data.Quota) data.Quota = [];
            if (!data.GVInfo) data.GVInfo = [];
            if (!data.Major) data.Major = ["QLCN", "ECom", "Logistics", "AI"];
            syncSchemas(data);
            localStorage.setItem('kltn_mockData', JSON.stringify(data));
            console.log("✅ Data loaded from Firebase (ERD-aligned)!");
            return data;
        } else {
            const cleanData = JSON.parse(JSON.stringify(defaultData));
            await setDoc(docRef, cleanData);
            localStorage.setItem('kltn_mockData', JSON.stringify(cleanData));
            console.log("✅ Default data (ERD-aligned) uploaded to Firebase!");
            return { ...defaultData };
        }
    } catch (e) {
        console.warn("⚠️ Firebase load failed, using localStorage fallback:", e);
        const stored = JSON.parse(localStorage.getItem('kltn_mockData')) || defaultData;
        syncSchemas(stored);
        return stored;
    }
}

/**
 * Save data: localStorage (sync) + Firebase (async background)
 */
export function saveData(data) {
    localStorage.setItem('kltn_mockData', JSON.stringify(data));
    
    try {
        const cleanData = JSON.parse(JSON.stringify(data));
        const docRef = doc(db, "appData", "main");
        setDoc(docRef, cleanData).then(() => {
            console.log("☁️ Synced to Firebase");
        }).catch(e => {
            console.warn("⚠️ Firebase save failed:", e);
        });
    } catch (e) {
        console.warn("⚠️ Firebase save error:", e);
    }
}
